# ============================================================
# Chapter 8 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ============================================================

# --- Section 8.3: External Tools Server ---
# Get a free key at https://www.weatherapi.com/
WEATHER_API_KEY="your_weatherapi_key_here"

# Get a free key at https://newsapi.org/
NEWS_API_KEY="your_newsapi_key_here"

# --- Section 8.4: Smart Home Server ---
# The local IP address of your Kasa smart plug (e.g. 192.168.1.42)
KASA_DEVICE_IP="your_kasa_device_ip_here"

# --- Section 8.4: Agent Client (LLM provider — use one) ---

# Option A: OpenAI (default) — get a key from https://platform.openai.com/
# Model used: gpt-5.4-nano
OPENAI_API_KEY="your_openai_api_key_here"
